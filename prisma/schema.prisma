generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id        String    @id @default(uuid(7))
  slug      String    @unique
  title     String
  body      String
  authorId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([authorId])
  @@index([deletedAt])
}

model ApiKey {
  id         String    @id @default(uuid(7))
  prefix     String
  hashedKey  String    @unique
  userId     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([hashedKey])
}
